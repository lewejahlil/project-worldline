# Worldline environment configuration
# Copy this file to .env and fill in the values.

# ── Registry / Driver ─────────────────────────────────────────────────────────

# URL of the remote registry JSON endpoint
REGISTRY_URL=http://localhost:3000/registry.json

# Port for the local Anvil devnet
DEVNET_PORT=8545

# ── Deployment ───────────────────────────────────────────────────────────────

# L1 RPC endpoint (for production deployments)
L1_RPC_URL=http://localhost:8545

# Deployer private key (DO NOT commit real keys — this is a dev placeholder only)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── Testnet RPC endpoints ─────────────────────────────────────────────────────

# Ethereum Sepolia testnet (used by: npm run deploy:sepolia)
SEPOLIA_RPC_URL=

# Ethereum Holesky testnet — chainId 17000 (used by: npm run deploy:holesky)
# NOTE: Goerli was shut down September 2023; use Holesky or Sepolia instead.
HOLESKY_RPC_URL=

# ── Contract deployment parameters ───────────────────────────────────────────

# bytes32 domain separator (keccak256 of a descriptive string)
DOMAIN_SEPARATOR=

# Maximum seconds a proof can be accepted after the window closes (default: 3600)
MAX_ACCEPTANCE_DELAY=3600

# Minimum timelock in seconds for OutputsRegistry schedule/activate (default: 86400 = 24h)
MIN_TIMELOCK=86400

# bytes32 program verifying key hash (generated from circuit artifacts)
PROGRAM_VKEY=

# bytes32 policy hash (keccak256 of canonical JSON policy)
POLICY_HASH=

# Set to "true" for dev/test deployments; MUST be "false" in production
IS_DEV_ADAPTER=false

# ── Watcher ───────────────────────────────────────────────────────────────────

# Address of the deployed WorldlineFinalizer contract
FINALIZER_ADDRESS=

# Expected policy hash for the watcher to validate on-chain events against
EXPECTED_POLICY_HASH=

# Start block for event queries (default: 0)
FROM_BLOCK=0

# ── Etherscan verification ────────────────────────────────────────────────────

# Etherscan API key for automatic contract verification after deployment.
# When set, scripts/deploy.ts will verify all deployed contracts on Etherscan.
# Leave blank to skip verification.
# Get a free key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# ── Gas benchmarks ────────────────────────────────────────────────────────────

# CoinMarketCap API key for USD gas cost estimates in hardhat-gas-reporter.
# Optional — gas reporting works without it (just no USD price conversion).
# Used by: npm run benchmark:sol  (or REPORT_GAS=true npx hardhat test)
# Get a free key at https://coinmarketcap.com/api/
CMC_API_KEY=

# ── Fork simulation ───────────────────────────────────────────────────────────

# Source RPC for Anvil fork mode (used by npm run sim:fork).
# Defaults to https://eth.llamarpc.com when unset.
# Start Anvil with:  anvil --fork-url "$FORK_RPC_URL" --port 8545
FORK_RPC_URL=

# Local Anvil fork endpoint (used by npm run sim:fork).
# Defaults to http://127.0.0.1:8545 when unset.
ANVIL_RPC_URL=http://127.0.0.1:8545
