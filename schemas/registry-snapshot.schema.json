{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldline.dev/schemas/registry-snapshot.schema.json",
  "title": "RegistrySnapshot",
  "description": "Schema for the Worldline on-disk registry snapshot format used by the Rust crates.",
  "type": "object",
  "required": ["schema_version", "circuits", "plugins", "backends"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version for forward-compatible parsing."
    },
    "circuits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "version"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "public_inputs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "version", "backend"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "backend": { "type": "string", "minLength": 1 }
        }
      }
    },
    "backends": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "versions": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
