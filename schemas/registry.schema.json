{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://worldline.dev/schemas/registry.json",
  "title": "Worldline Registry Snapshot",
  "type": "object",
  "required": ["circuits", "drivers", "plugins"],
  "properties": {
    "circuits": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["id", "description", "verifier", "abi_uri"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "verifier": { "type": "string" },
          "abi_uri": { "type": "string", "format": "uri" }
        }
      }
    },
    "drivers": {
      "type": "object"
    },
    "plugins": {
      "type": "object"
    }
  }
}
