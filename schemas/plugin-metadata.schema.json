{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://worldline.dev/schemas/plugin-metadata.json",
  "title": "Worldline Plugin Metadata",
  "type": "object",
  "required": ["id", "version", "implementation", "circuitId"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Keccak-256 hash of the plugin slug",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "version": {
      "type": "string",
      "description": "Semver version of the plugin"
    },
    "implementation": {
      "type": "string",
      "description": "Ethereum address of the plugin implementation",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    },
    "circuitId": {
      "type": "string",
      "description": "Identifier of the circuit used to verify plugin proofs",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "deprecated": {
      "type": "boolean",
      "default": false
    }
  }
}
