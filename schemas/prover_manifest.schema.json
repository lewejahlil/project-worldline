{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Prover Manifest",
  "type": "object",
  "required": ["prover_id","family","version","vkey_commitment",
               "image_digest","cmd","env_required","timeout_ms"],
  "properties": {
    "prover_id": { "type": "string", "maxLength": 64 },
    "family": {
      "type": "string",
      "enum": ["SNARK","STARK","Hybrid","Other"]
    },
    "version": { "type": "string" },
    "vkey_commitment": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "image_digest": { "type": "string", "pattern": "^sha256:[0-9a-fA-F]{64}$" },
    "cosign_subject": { "type": "string" },
    "cmd": { "type": "array", "items": { "type": "string" } },
    "env_required": { "type": "array", "items": { "type": "string" } },
    "timeout_ms": { "type": "integer", "minimum": 1000 }
  },
  "additionalProperties": false
}
