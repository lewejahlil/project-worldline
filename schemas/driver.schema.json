{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://worldline.dev/schemas/driver.json",
  "title": "Worldline Driver Metadata",
  "type": "object",
  "required": ["id", "version", "endpoint"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "version": {
      "type": "string"
    },
    "endpoint": {
      "type": "string",
      "format": "uri"
    }
  }
}
