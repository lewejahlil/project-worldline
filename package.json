{
  "name": "worldline",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run contracts:build",
    "contracts:build": "hardhat compile",
    "contracts:test": "hardhat test",
    "devnet": "node devnet/index.js",
    "devnet:smoke": "ts-node devnet/smoke.ts",
    "benchmark:sol": "REPORT_GAS=true npx hardhat test",
    "sim:fork": "ts-node scripts/fork-sim.ts",
    "deploy:sepolia": "npx hardhat run scripts/deploy.ts --network sepolia",
    "deploy:holesky": "npx hardhat run scripts/deploy.ts --network holesky",
    "lint": "eslint \"{contracts,plugins}/**/*.{ts,tsx}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "c:ptau": "ts-node circuits/scripts/download-ptau.ts",
    "c:compile": "mkdir -p circuits/artifacts && circom circuits/worldline.circom --wasm --r1cs --output circuits/artifacts",
    "c:setup:phase2begin": "snarkjs groth16 setup circuits/artifacts/worldline.r1cs circuits/ptau/powersOfTau28_hez_final_10.ptau circuits/artifacts/worldline_0000.zkey",
    "c:setup:contribute": "snarkjs zkey contribute circuits/artifacts/worldline_0000.zkey circuits/artifacts/worldline_0001.zkey --name=\"Contributor\" -v -e=\"$(node -e 'process.stdout.write(require(\"crypto\").randomBytes(32).toString(\"hex\"))')\"",
    "c:setup:beacon": "snarkjs zkey beacon circuits/artifacts/worldline_0001.zkey circuits/artifacts/worldline_final.zkey 0102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f20 10 -n=\"Final Beacon\"",
    "c:setup:verify": "snarkjs zkey verify circuits/artifacts/worldline.r1cs circuits/ptau/powersOfTau28_hez_final_10.ptau circuits/artifacts/worldline_final.zkey",
    "c:setup": "npm run c:setup:phase2begin && npm run c:setup:contribute && npm run c:setup:beacon && npm run c:setup:verify",
    "c:export": "ts-node circuits/scripts/export-verifier.ts",
    "watcher": "ts-node scripts/watcher.ts",
    "test": "npm run contracts:test && cargo test"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@types/chai": "^4.3.5",
    "@types/mocha": "^10.0.2",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "chai": "^4.4.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.10",
    "prettier": "^3.1.1",
    "snarkjs": "0.7.6",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "c-kzg": "^4.1.0",
    "ethers": "^6.8.1"
  }
}
