{
  "name": "worldline",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run contracts:build",
    "contracts:build": "hardhat compile",
    "contracts:test": "hardhat test",
    "devnet": "node devnet/index.js",
    "devnet:smoke": "ts-node devnet/smoke.ts",
    "benchmark:sol": "REPORT_GAS=true npx hardhat test",
    "sim:fork": "ts-node scripts/fork-sim.ts",
    "deploy:sepolia": "npx hardhat run scripts/deploy.ts --network sepolia",
    "deploy:goerli": "npx hardhat run scripts/deploy.ts --network goerli",
    "deploy:holesky": "npx hardhat run scripts/deploy.ts --network holesky",
    "lint": "eslint \"{contracts,plugins}/**/*.{ts,tsx}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "c:ptau": "ts-node circuits/scripts/download-ptau.ts",
    "c:compile": "npx --yes circom@2.1.6 circuits/worldline.circom --wasm --r1cs --output circuits/artifacts",
    "c:setup": "snarkjs groth16 setup circuits/artifacts/worldline.r1cs circuits/ptau/powersOfTau28_hez_final_10.ptau circuits/artifacts/worldline_final.zkey",
    "c:export": "ts-node circuits/scripts/export-verifier.ts",
    "watcher": "ts-node scripts/watcher.ts",
    "test": "npm run contracts:test && cargo test"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@types/chai": "^4.3.5",
    "@types/mocha": "^10.0.2",
    "@types/node": "^20.11.5",
    "chai": "^4.4.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.10",
    "prettier": "^3.1.1",
    "snarkjs": "^0.7.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "ethers": "^6.8.1"
  }
}
